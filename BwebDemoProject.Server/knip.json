{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["server.js", "routes/**/*.js", "controllers/**/*.js"],
  "project": ["**/*.js"],
  "ignore": ["node_modules/**"],
  "ignoreDependencies": [],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "unlisted": "error",
    "exports": "error"
  }
}
