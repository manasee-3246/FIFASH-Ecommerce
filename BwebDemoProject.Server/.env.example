# ============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values
# NEVER commit .env file with real credentials!
# ============================================

# ============ DATABASE ============
# MongoDB connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
DATABASE="mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority"

# ============ SERVER ============
PORT=7002
NODE_ENV=development
# Set to 'production' in production environment

# ============ API CONFIGURATION ============
REACT_APP_API_URL="your-domain.com"

# ============ JWT CONFIGURATION ============
# Generate strong secrets using: https://jwtsecretkeygenerator.com/
# Or use: node -e "console.log(require('crypto').randomBytes(256).toString('base64'))"
# IMPORTANT: These should be at least 256 characters for security

ADMIN_JWT_SECRET_KEY="REPLACE_WITH_STRONG_SECRET_KEY_AT_LEAST_256_CHARS"
EMPLOYEE_JWT_SECRET_KEY="REPLACE_WITH_DIFFERENT_STRONG_SECRET_KEY"
JWT_EXPIRY=7d

# ============ RATE LIMITING ============
# Optional - Override default rate limits
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# AUTH_RATE_LIMIT_MAX=5

# ============ CORS ============
# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ============ SECURITY ============
# Set to true in production to enable stricter security
# STRICT_SECURITY=false

# ============ EXTERNAL SERVICES ============
# If using email services, configure here
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password

# If using AWS S3 for file storage
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1

# ============ NOTES ============
# 1. Never commit this file with real credentials
# 2. Use strong, unique passwords for all services
# 3. Rotate JWT secrets periodically
# 4. Keep this file restricted (chmod 600 on Linux)
